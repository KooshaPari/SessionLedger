# SessionLedger Alertmanager route ID stubs (C05 L48).
# Copy to a local, gitignored env file and replace REPLACE_ME_* values before
# production paging. Do not commit live webhook URLs, channel IDs, or routing keys.
#
# Soft check (stubs OK):
#   pwsh -NoProfile -File scripts/alert-route-ids-check.ps1
# Strict (requires non-stub env):
#   pwsh -NoProfile -File scripts/alert-route-ids-check.ps1 -Strict

# Slack incoming-webhook URL for Alertmanager slack_configs.api_url
SL_ALERT_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE_ME/SLACK/WEBHOOK

# Slack channel ID for #sessionledger-ops (CABCDEF01234-style); not a secret token
SL_ALERT_SLACK_CHANNEL_ID=REPLACE_ME_SLACK_CHANNEL_ID

# PagerDuty Events API v2 routing key for sessionledger-pagerduty receiver
SL_ALERT_PAGERDUTY_ROUTING_KEY=REPLACE_ME_PAGERDUTY_ROUTING_KEY
