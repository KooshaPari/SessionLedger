(( $+functions[_sl-daemon_commands] )) ||
_sl-daemon_commands() {
    local commands; commands=(
'serve:Start the file-watcher daemon' \
'status:Check daemon status (exit 0 = running, exit 1 = not running)' \
'list:List compiled OKF bundle paths (one per line)' \
'tail:Stream new bundle paths as they arrive (SSE). Press Ctrl+C to stop' \
'export:Export bundle metadata as CSV, Markdown, or JSON' \
'summary:Print aggregate statistics across all bundles' \
'tag:Manage tags on OKF bundle files' \
'archive:Archive bundles older than a given date by gzipping them' \
'restore:Restore a previously archived bundle by decompressing it' \
'replay:Replay a compiled OKF bundle, streaming its entities in chronological order.  Connects to the running daemon'\''s SSE endpoint unless \`--bundle\` points to a local file' \
'validate:Validate an OKF bundle on disk against ingest rules' \
'search:Search / filter bundles by date, model, token count, or tags' \
'completions:Generate shell completion scripts to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'sl-daemon commands' commands "$@"
}
