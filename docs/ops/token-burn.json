      "expected_total_token_estimate": 370,
      "intent_token_estimates": [210, 160]
    },
    {
      "path": "docs/reference/conformance/fixtures/task-family-compress-resume-033.okf.json",
      "expected_total_token_estimate": 360,
      "intent_token_estimates": [240, 120]
    },
    {
      "path": "docs/reference/conformance/fixtures/compress-token-proxy-034.okf.json",
      "expected_total_token_estimate": 270,
      "intent_token_estimates": [180, 90]
    },
    {
      "path": "docs/reference/conformance/fixtures/token-slice-budget-035.okf.json",
      "expected_total_token_estimate": 280,
      "intent_token_estimates": [160, 120]
    },
    {
      "path": "docs/reference/conformance/fixtures/archive-gzip-resume-036.okf.json",
      "expected_total_token_estimate": 310,
      "intent_token_estimates": [200, 110]
    }
  ],
  "metrics_surface": {
