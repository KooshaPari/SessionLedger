<?xml version="1.0" encoding="UTF-8"?>
<!-- WiX v4 per-user MSI. Built by scripts/package-msi.ps1 (unsigned; Authenticode deferred). -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="SessionLedger Viewer"
    Manufacturer="SessionLedger"
    Version="$(var.Version)"
    UpgradeCode="D890E057-2453-4D53-BF57-880A523D2741"
    Scope="perUser">
    <MajorUpgrade DowngradeErrorMessage="A newer SessionLedger version is installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="SessionLedger Viewer">
      <ComponentGroupRef Id="ApplicationComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="SessionLedger" />
      </Directory>
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ApplicationComponents" Directory="INSTALLFOLDER">
      <Component Guid="*">
        <File Id="ViewerExecutable" Source="$(var.SourceDir)\sl-viewer.exe">
          <Shortcut
            Id="StartMenuShortcut"
            Directory="ProgramMenuFolder"
            Name="SessionLedger"
            WorkingDirectory="INSTALLFOLDER"
            Advertise="no" />
        </File>
        <RegistryValue
          Root="HKCU"
          Key="Software\SessionLedger"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
        <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
      </Component>
      <Component Guid="*">
        <File Source="$(var.SourceDir)\LICENSE-MIT" />
      </Component>
      <Component Guid="*">
        <File Source="$(var.SourceDir)\LICENSE-APACHE" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
